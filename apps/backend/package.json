{
  "name": "@avo/backend",
  "version": "0.1.0",
  "private": true,
  "main": "./src/server.ts",
  "types": "./src/types.ts",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/src/server.d.ts",
      "default": "./src/server.ts"
    },
    "./types": {
      "types": "./dist/src/types.d.ts",
      "default": "./src/types.ts"
    },
    "./app": {
      "types": "./dist/src/app.d.ts",
      "default": "./src/app.ts"
    }
  },
  "scripts": {
    "dev": "docker compose up -d db && bun run --hot src/server.ts",
    "worker:dev": "bun run --hot src/worker/index.ts",
    "worker:start": "bun run src/worker/index.ts",
    "start": "bun run src/server.ts",
    "start:railway": "bun run db:migrate && bun run start",
    "build": "bunx tsc --build",
    "type-check": "bunx tsc --noEmit",
    "db:generate": "bunx -b drizzle-kit generate",
    "db:migrate": "bun run -b src/db/migrate.ts",
    "db:push": "bunx -b drizzle-kit push",
    "db:reset": "bun run -b src/db/reset.ts",
    "db:seed": "bun run -b src/db/seed.ts",
    "db:seed-lite": "bun run -b src/db/seed-lite.ts",
    "db:studio": "bunx -b drizzle-kit studio",
    "partner:seed": "bun run -b scripts/seed-partner.ts",
    "db:auth-generate": "bunx --bun @better-auth/cli generate",
    "lint": "bunx ultracite fix",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@hono/zod-validator": "^0.7.5",
    "@openrouter/ai-sdk-provider": "^2.5.1",
    "@supabase/supabase-js": "^2.49.1",
    "ai": "^6.0.158",
    "better-auth": "catalog:",
    "date-fns": "catalog:",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "graphile-worker": "^0.16.6",
    "hono": "catalog:",
    "openai": "^6.1.0",
    "pg": "^8.16.3",
    "pino": "^9.7.0",
    "resend": "^6.10.0",
    "zod": "catalog:",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.9",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.7",
    "pino-pretty": "^13.1.2"
  }
}
