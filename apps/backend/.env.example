DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
APPLICATION_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-frontend-domain.com,https://your-admin-domain.com
BETTER_AUTH_URL=https://your-backend-domain.com
BETTER_AUTH_COOKIE_DOMAIN=.your-domain.com
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
GOOGLE_PLACES_API_KEY=replace-with-your-google-places-key
OPENROUTER_API_KEY=replace-with-your-openrouter-api-key
SENTRY_DSN=
PORT=4000
