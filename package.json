{
  "name": "avo",
  "private": true,
  "version": "0.0.0",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@hookform/resolvers": "^5.2.2",
      "@tanstack/react-query": "^5.90.11",
      "@tanstack/react-table": "^8.21.3",
      "better-auth": "^1.4.3",
      "class-variance-authority": "^0.7.1",
      "clsx": "^2.1.1",
      "cmdk": "^1.1.1",
      "date-fns": "^4.1.0",
      "hono": "4.10.6",
      "lucide-react": "^0.555.0",
      "next": "^16.1.6",
      "next-themes": "^0.4.6",
      "radix-ui": "^1.4.3",
      "react": "19.2.0",
      "react-day-picker": "^9.14.0",
      "react-dom": "19.2.0",
      "react-hook-form": "^7.71.1",
      "react-resizable-panels": "^4.10.0",
      "sonner": "^2.0.7",
      "tailwind-merge": "^3.5.0",
      "zod": "^4.1.13"
    }
  },
  "scripts": {
    "dev": "bun --filter '*' dev",
    "dev:admin": "bun --filter @avo/admin dev",
    "dev:web": "bun --filter @avo/web dev",
    "dev:public": "bun --filter @avo/public dev",
    "dev:backend": "bun --filter @avo/backend dev",
    "build": "bun --filter '*' build",
    "lint": "bun x ultracite fix",
    "check": "bun x ultracite check",
    "type-check": "bun --filter '*' type-check",
    "db:studio": "bun --filter @avo/backend db:studio",
    "db:migrate": "bun --filter @avo/backend db:migrate",
    "db:generate": "bun --filter @avo/backend db:generate",
    "db:push": "bun --filter @avo/backend db:push",
    "db:reset": "bun --filter @avo/backend db:reset",
    "db:seed": "bun --filter @avo/backend db:seed",
    "db:seed-lite": "bun --filter @avo/backend db:seed-lite",
    "db:auth-generate": "bun --filter @avo/backend db:auth-generate",
    "prepare": "[ -d .git ] && lefthook install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "lefthook": "^2.0.16",
    "typescript": "^5",
    "ultracite": "7.1.3"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.3"
  },
  "packageManager": "bun@1.3.9"
}
